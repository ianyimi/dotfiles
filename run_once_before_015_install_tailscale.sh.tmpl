{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash

set -e

echo "=== Installing Tailscale (open-source CLI/daemon) ==="

# We intentionally install the Homebrew *formula*, NOT the cask.
#
# The macOS App Store / standalone GUI builds are sandboxed and cannot run
# the Tailscale SSH server, so `tailscale set --ssh` fails with:
#   "The Tailscale SSH server does not run in sandboxed Tailscale GUI builds."
# See: https://tailscale.com/kb/1065/macos-variants
#
# The formula installs `tailscaled` as a background service, which supports
# Tailscale SSH, exit nodes, subnet routing, and everything else.

# Warn if the sandboxed GUI app is still present
if [ -d "/Applications/Tailscale.app" ]; then
    echo "⚠️  /Applications/Tailscale.app is installed (sandboxed GUI variant)."
    echo "    Tailscale SSH will NOT work while that variant is the active client."
    echo "    Quit it (and optionally delete it) before continuing."
    echo ""
fi

# Install the open-source tailscaled formula if missing
if ! brew list --formula tailscale >/dev/null 2>&1; then
    echo "Installing tailscale formula..."
    brew install tailscale
else
    echo "✓ tailscale formula already installed"
fi

# Start the daemon as a root service so it can manage networking
if ! sudo brew services list | grep -E '^tailscale\s+started' >/dev/null 2>&1; then
    echo "Starting tailscaled via brew services..."
    sudo brew services start tailscale
else
    echo "✓ tailscaled already running"
fi

echo ""
echo "=== Next steps ==="
echo "  1. Authenticate:     sudo tailscale up --ssh"
echo "     (or if already up: tailscale set --ssh)"
echo "  2. Verify:           tailscale status"
echo ""
echo "=== Tailscale setup complete ==="
{{ end -}}
